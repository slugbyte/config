#!/bin/bash
# vnew - Create a new empty jj change
#
# Creates a new empty change in jj repositories without describing
# the current one. For committing work, use vcommit instead.
#
# Usage:
#   vnew [jj-new-args...]
#
# Examples:
#   vnew                       # new empty change
#   vnew -m "wip"              # new change with message

[[ "$1" == "--describe" ]] && echo "Create a new empty jj change" && exit 0

if [[ "$1" == "--help" ]]; then
    echo "Usage: vnew [jj-new-args...]"
    echo ""
    echo "Create a new empty jj change (jj only)."
    echo "For committing work in either jj or git, use vcommit."
    exit 0
fi

vcs_info=$(vdetect) || exit 1
vcs="${vcs_info%% *}"

if [[ "$vcs" != "jj" ]]; then
    echo "ERROR: vnew is only supported in jj repositories" >&2
    echo "Use 'vcommit' to commit work in git repositories." >&2
    exit 1
fi

jj new "$@"
